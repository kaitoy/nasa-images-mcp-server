{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kaitoy/nasa-images-mcp-server",
  "description": "MCP server with UI for NASA images",
  "repository": {
    "url": "https://github.com/kaitoy/nasa-images-mcp-server",
    "source": "github"
  },
  "version": "1.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@kaitoy/nasa-images-mcp-server",
      "version": "1.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the NASA Images API",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "NASA_API_KEY"
        }
      ]
    }
  ]
}
